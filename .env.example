# Brain connection
BRAIN_URL=http://localhost:3001
BRAIN_API_KEY=replace-with-brain-api-key

# Render service (TemplateV1)
RENDER_SERVICE_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-4o-mini

# Generator auth (generate with: openssl rand -hex 32)
GENERATOR_API_KEY=replace-with-generator-api-key

# Template
INSTAGRAM_TEMPLATE_ID=cover-template-v1
GENERATOR_PLATFORM=instagram
GENERATOR_FORMAT=feed_post
GENERATOR_CHANNEL_KEY=
GENERATOR_PLAYBOOK_PATH=playbooks/instagram-news-core.json

# Cloudinary (signed upload)
CLOUDINARY_CLOUD_NAME=replace-with-cloudinary-cloud-name
CLOUDINARY_API_KEY=replace-with-cloudinary-api-key
CLOUDINARY_API_SECRET=replace-with-cloudinary-api-secret

# Server
PORT=3002

# Error monitoring (optional)
# SENTRY_DSN=https://your-sentry-dsn.ingest.sentry.io/...
